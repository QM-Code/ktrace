@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

if(@KARMA_ENGINE_PACKAGE_HAS_CLIENT@ AND @KARMA_ENGINE_PACKAGE_WITH_IMGUI@)
    if(NOT TARGET imgui::imgui)
        find_dependency(imgui CONFIG REQUIRED)
    endif()
endif()

if(@KARMA_ENGINE_PACKAGE_HAS_CLIENT@ AND @KARMA_ENGINE_PACKAGE_WITH_RMLUI@)
    if(NOT TARGET RmlUi::RmlUi)
        find_dependency(RmlUi CONFIG REQUIRED)
    endif()
endif()

find_dependency(glm REQUIRED)
find_dependency(assimp REQUIRED)
find_dependency(spdlog REQUIRED)
find_dependency(miniz REQUIRED)
find_dependency(nlohmann_json REQUIRED)
find_dependency(CURL REQUIRED)

if(@KARMA_ENGINE_PACKAGE_HAS_CLIENT@)
    if(@KARMA_ENGINE_PACKAGE_WITH_X11@)
        find_dependency(X11 REQUIRED)
    endif()

    if("@KARMA_WINDOW_BACKEND@" STREQUAL "sdl3")
        find_dependency(SDL3 CONFIG REQUIRED)
    endif()

    if(@KARMA_ENGINE_PACKAGE_WITH_RENDER_BGFX@)
        find_dependency(bgfx CONFIG REQUIRED)
    endif()

    if(@KARMA_ENGINE_PACKAGE_WITH_RENDER_DILIGENT@)
        find_dependency(DiligentEngine CONFIG REQUIRED)
    endif()
endif()

include("${CMAKE_CURRENT_LIST_DIR}/KarmaEngineTargets.cmake")
check_required_components(KarmaEngine)
