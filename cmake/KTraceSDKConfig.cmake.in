@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(spdlog CONFIG REQUIRED)
find_dependency(KcliSDK CONFIG REQUIRED)

include("${CMAKE_CURRENT_LIST_DIR}/KTraceSDKTargets.cmake")

if(NOT TARGET ktrace::sdk)
    if(TARGET ktrace::sdk_shared)
        add_library(ktrace::sdk INTERFACE IMPORTED)
        set_property(TARGET ktrace::sdk PROPERTY
            INTERFACE_LINK_LIBRARIES ktrace::sdk_shared
        )
    elseif(TARGET ktrace::sdk_static)
        add_library(ktrace::sdk INTERFACE IMPORTED)
        set_property(TARGET ktrace::sdk PROPERTY
            INTERFACE_LINK_LIBRARIES ktrace::sdk_static
        )
    endif()
endif()

check_required_components(KTraceSDK)
