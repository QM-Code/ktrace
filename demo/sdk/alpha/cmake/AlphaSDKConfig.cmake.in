@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(KtraceSDK CONFIG REQUIRED)

include("${CMAKE_CURRENT_LIST_DIR}/AlphaSDKTargets.cmake")

if(NOT TARGET alpha::sdk)
    if(TARGET alpha::sdk_shared)
        add_library(alpha::sdk INTERFACE IMPORTED)
        set_property(TARGET alpha::sdk PROPERTY
            INTERFACE_LINK_LIBRARIES alpha::sdk_shared
        )
    elseif(TARGET alpha::sdk_static)
        add_library(alpha::sdk INTERFACE IMPORTED)
        set_property(TARGET alpha::sdk PROPERTY
            INTERFACE_LINK_LIBRARIES alpha::sdk_static
        )
    endif()
endif()

check_required_components(AlphaSDK)
